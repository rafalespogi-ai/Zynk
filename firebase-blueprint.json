{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A message posted to the public board.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The content of the message."
        },
        "author": {
          "type": "string",
          "description": "The name of the person who posted the message."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was created."
        },
        "uid": {
          "type": "string",
          "description": "The UID of the user who posted the message."
        }
      },
      "required": ["text", "author", "createdAt"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Public messages collection."
    }
  }
}
