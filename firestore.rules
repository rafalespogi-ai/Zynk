rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: messages
    // Document ID: {messageId}
    // Fields:
    //   - text: string (required, 1-500 chars)
    //   - author: string (required, 1-50 chars)
    //   - createdAt: timestamp (required)
    //   - uid: string (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'author', 'createdAt']) &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 500 &&
             data.author is string && data.author.size() > 0 && data.author.size() <= 50 &&
             data.createdAt is timestamp;
    }

    match /messages/{messageId} {
      // Anyone can read messages
      allow read: if true;
      
      // Only authenticated users can create messages
      allow create: if isAuthenticated() && 
                      isValidMessage(request.resource.data) &&
                      (request.resource.data.uid == request.auth.uid || !('uid' in request.resource.data));
      
      // Only owners can delete their messages
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
      
      // Updates are not allowed for simplicity in this demo
      allow update: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }
  }
}
